generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // No url field here - it's in prisma.config.ts
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}